// SETUP
// ================================================================
void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  // OLED boot screen
  display.begin(0x3C, true);
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);
  display.setCursor(0, 0);
  display.println("SMART BIN IoT v2");
  display.println("Group 5 IT38B NBSC");
  display.println("Booting...");
  display.display();

  // GPIO setup
  pinMode(LED_BIO_RED,      OUTPUT);
  pinMode(LED_BIO_GREEN,    OUTPUT);
  pinMode(LED_NONBIO_RED,   OUTPUT);
  pinMode(LED_NONBIO_GREEN, OUTPUT);
  pinMode(BUZZER,           OUTPUT);
  pinMode(TRIG1,            OUTPUT);
  pinMode(ECHO1,            INPUT);
  pinMode(TRIG2,            OUTPUT);
  pinMode(ECHO2,            INPUT);
  pinMode(XSHUT1,           OUTPUT);
  pinMode(XSHUT2,           OUTPUT);

  // Safe defaults
  digitalWrite(LED_BIO_GREEN,    HIGH);
  digitalWrite(LED_NONBIO_GREEN, HIGH);
  digitalWrite(BUZZER,           LOW);

  // Servo init
  servo1.setPeriodHertz(50);
  servo2.setPeriodHertz(50);
  servo1.attach(SERVO1_PIN, 500, 2400);
  servo2.attach(SERVO2_PIN, 500, 2400);
  servo1.write(SERVO_CLOSED);
  servo2.write(SERVO_CLOSED);

  // VL53L0X initialization (original sequence preserved)
  digitalWrite(XSHUT1, LOW);
  digitalWrite(XSHUT2, LOW);
  delay(100);

  digitalWrite(XSHUT1, HIGH);
  delay(100);
  if (sensor1.init()) {
    sensor1.setAddress(0x30);
    sensor1.setTimeout(500);
    Serial.println("[VL53L0X] BIO sensor OK at 0x30");
  } else {
    Serial.println("[VL53L0X] BIO sensor FAILED");
  }

  digitalWrite(XSHUT2, HIGH);
  delay(100);
  if (sensor2.init()) {
    sensor2.setAddress(0x31);
    sensor2.setTimeout(500);
    Serial.println("[VL53L0X] NON-BIO sensor OK at 0x31");
  } else {
    Serial.println("[VL53L0X] NON-BIO sensor FAILED");
  }

  // WiFi
  display.clearDisplay();
  display.setCursor(0, 0);
  display.println("Connecting WiFi...");
  display.display();

  connectWiFi();

  // Push startup event to Supabase
  postBinLog(
    0, 0,           // bio_level, nb_level
    0, 0,           // bio_distance_mm, nb_distance_mm
    "0% FULL", "0% FULL",
    false, false,
    "startup",      // event_type
    "",             // alert_bin = NULL
    "ESP32 booted"
  );

  Serial.println("[System] READY");
  lastSupabasePush = millis();
  lastUptimeTick   = millis();
}


// ================================================================
// LOOP
// ================================================================
void loop() {
  unsigned long now = millis();

  // ── Uptime counter ──────────────────────────────────────────
  if (now - lastUptimeTick >= 1000) {
    uptimeSeconds++;
    lastUptimeTick = now;
  }

  // ── WiFi reconnect watchdog ──────────────────────────────────
  if (WiFi.status() != WL_CONNECTED) {
    static unsigned long lastReconnect = 0;
    if (now - lastReconnect >= 30000) {
      lastReconnect = now;
      Serial.println("[WiFi] Reconnecting...");
      WiFi.reconnect();
    }
  }

  // ────────────────────────────────────────────────────────────
  // 1. READ VL53L0X DISTANCE SENSORS
  // ────────────────────────────────────────────────────────────
  int d1 = sensor1.readRangeSingleMillimeters(); // BIO
  int d2 = sensor2.readRangeSingleMillimeters(); // NON-BIO

  int bioLevel = mmToLevel(d1);
  int nbLevel  = mmToLevel(d2);

  String bioStatus = levelToStatus(bioLevel);
  String nbStatus  = levelToStatus(nbLevel);

  // ────────────────────────────────────────────────────────────
  // 2. READ ULTRASONIC SENSORS (original logic)
  // ────────────────────────────────────────────────────────────
  float bioDist   = getDistanceInches(TRIG1, ECHO1);
  float nonBioDist = getDistanceInches(TRIG2, ECHO2);

  // ────────────────────────────────────────────────────────────
  // 3. LED LOGIC (original, unchanged)
  // ────────────────────────────────────────────────────────────
  digitalWrite(LED_BIO_RED,      (bioStatus == "100% FULL") ? HIGH : LOW);
  digitalWrite(LED_BIO_GREEN,    (bioStatus != "100% FULL") ? HIGH : LOW);
  digitalWrite(LED_NONBIO_RED,   (nbStatus  == "100% FULL") ? HIGH : LOW);
  digitalWrite(LED_NONBIO_GREEN, (nbStatus  != "100% FULL") ? HIGH : LOW);

  // ────────────────────────────────────────────────────────────
  // 4. BIO BIN — SERVO & BUZZER (original logic, unchanged)
  // ────────────────────────────────────────────────────────────
  if (bioDist <= 5.0 && !bioBuzzLock) {
    bioBuzzLock = true;
    if (bioStatus == "100% FULL") fullBeep(); else shortBeep();
  }
  if (bioDist > 6.0) bioBuzzLock = false;

  if (bioDist <= 5.0 && !bioServoOpen
      && bioStatus != "100% FULL"
      && bioStatus != "SENSOR ERR") {
    servo1.write(SERVO_OPEN);
    bioServoOpen = true;
    bioTimer = now;
  }
  if (bioServoOpen && now - bioTimer >= 3000) {
    servo1.write(SERVO_CLOSED);
    bioServoOpen = false;
  }

  // ────────────────────────────────────────────────────────────
  // 5. NON-BIO BIN — SERVO & BUZZER (original logic, unchanged)
  // ────────────────────────────────────────────────────────────
  if (nonBioDist <= 5.0 && !nonBioBuzzLock) {
    nonBioBuzzLock = true;
    if (nbStatus == "100% FULL") fullBeep(); else shortBeep();
  }
  if (nonBioDist > 6.0) nonBioBuzzLock = false;

  if (nonBioDist <= 5.0 && !nonBioServoOpen
      && nbStatus != "100% FULL"
      && nbStatus != "SENSOR ERR") {
    servo2.write(SERVO_OPEN);
    nonBioServoOpen = true;
    nonBioTimer = now;
  }
  if (nonBioServoOpen && now - nonBioTimer >= 3000) {
    servo2.write(SERVO_CLOSED);
    nonBioServoOpen = false;
  }

  // ────────────────────────────────────────────────────────────
  // 6. THRESHOLD ALERTS — GAS email + Supabase alert row
  //    Only fires once per crossing (reset when bin clears)
  // ────────────────────────────────────────────────────────────

  // BIO — 75% warning
  if (bioLevel == 75 && !bioWarnSent) {
    bioWarnSent = true;
    Serial.println("[ALERT] Bio bin at 75%");
    // Insert alert row to bin_logs — trigger writes to alert_history
    postBinLog(
      bioLevel, nbLevel, d1, d2,
      bioStatus, nbStatus,
      bioServoOpen, nonBioServoOpen,
      "alert", "bio", "75% threshold reached"
    );
    sendGASAlert("Biodegradable", bioLevel, "warn");
  }
  // Reset warn flag when level drops below 75
  if (bioLevel < 75) bioWarnSent = false;

  // BIO — 100% full
  if (bioLevel == 100 && !bioFullSent) {
    bioFullSent = true;
    Serial.println("[ALERT] Bio bin FULL");
    postBinLog(
      bioLevel, nbLevel, d1, d2,
      bioStatus, nbStatus,
      bioServoOpen, nonBioServoOpen,
      "alert", "bio", "Bin full"
    );
    sendGASAlert("Biodegradable", bioLevel, "full");
  }
  // Reset full flag when bin is emptied
  if (bioLevel < 100) bioFullSent = false;

  // NON-BIO — 75% warning
  if (nbLevel == 75 && !nonBioWarnSent) {
    nonBioWarnSent = true;
    Serial.println("[ALERT] Non-Bio bin at 75%");
    postBinLog(
      bioLevel, nbLevel, d1, d2,
      bioStatus, nbStatus,
      bioServoOpen, nonBioServoOpen,
      "alert", "nonbio", "75% threshold reached"
    );
    sendGASAlert("Non-Biodegradable", nbLevel, "warn");
  }
  if (nbLevel < 75) nonBioWarnSent = false;

  // NON-BIO — 100% full
  if (nbLevel == 100 && !nonBioFullSent) {
    nonBioFullSent = true;
    Serial.println("[ALERT] Non-Bio bin FULL");
    postBinLog(
      bioLevel, nbLevel, d1, d2,
      bioStatus, nbStatus,
      bioServoOpen, nonBioServoOpen,
      "alert", "nonbio", "Bin full"
    );
    sendGASAlert("Non-Biodegradable", nbLevel, "full");
  }
  if (nbLevel < 100) nonBioFullSent = false;

  // ────────────────────────────────────────────────────────────
  // 7. ROUTINE SUPABASE PUSH (every SUPABASE_INTERVAL ms)
  //    Only for non-error sensor readings.
  //    Trigger trg_update_device_status keeps device_status fresh.
  // ────────────────────────────────────────────────────────────
  if (now - lastSupabasePush >= SUPABASE_INTERVAL) {
    lastSupabasePush = now;

    if (bioLevel >= 0 && nbLevel >= 0) {  // skip on sensor error
      postBinLog(
        bioLevel, nbLevel,
        d1, d2,
        bioStatus, nbStatus,
        bioServoOpen, nonBioServoOpen,
        "reading",  // event_type
        "",         // alert_bin = NULL for routine readings
        ""
      );
    }

    // Also update uptime in device_status
    updateDeviceUptime();
  }

  // ────────────────────────────────────────────────────────────
  // 8. OLED UPDATE (original priority logic, unchanged)
  // ────────────────────────────────────────────────────────────
  updateOLED(
    bioStatus, nbStatus,
    bioDist, nonBioDist,
    WiFi.status() == WL_CONNECTED
  );

  // ────────────────────────────────────────────────────────────
  // 9. SERIAL DEBUG (original output preserved)
  // ────────────────────────────────────────────────────────────
  Serial.print("BIO: ");  Serial.print(d1); Serial.print("mm | ");
  Serial.print("NON: ");  Serial.print(d2); Serial.println("mm");
  Serial.print("BIO%: "); Serial.print(bioLevel);
  Serial.print("  NB%: ");Serial.println(nbLevel);
  Serial.print("BIO_US: ");    Serial.print(bioDist);
  Serial.print("in  NON_US: "); Serial.print(nonBioDist); Serial.println("in");
  Serial.println("--------------------");

  delay(50); // original loop delay preserved
}
