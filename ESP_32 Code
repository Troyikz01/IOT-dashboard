void connectWiFi() {
  Serial.print("[WiFi] Connecting to "); Serial.print(WIFI_SSID);
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 20) {
    delay(500); Serial.print("."); tries++;
  }
  if (WiFi.status() == WL_CONNECTED)
    Serial.println("\n[WiFi] Connected! IP: " + WiFi.localIP().toString());
  else
    Serial.println("\n[WiFi] FAILED — running offline.");
}


// ================================================================
// SUPABASE — push bin_logs heartbeat
// ================================================================
bool pushBinLog(int bioLvl, int nbLvl,
                int bioMM,  int nbMM,
                bool bioOpen, bool nbOpen) {
  if (WiFi.status() != WL_CONNECTED) return false;

  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = String(SUPABASE_URL) + "/rest/v1/bin_logs";
  http.begin(client, url);
  http.addHeader("Content-Type",  "application/json");
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);
  http.addHeader("Prefer",        "return=minimal");

  StaticJsonDocument<256> doc;
  doc["device_id"]       = DEVICE_ID;
  doc["bio_level"]       = (bioLvl < 0) ? 0 : bioLvl;
  doc["nb_level"]        = (nbLvl  < 0) ? 0 : nbLvl;
  doc["bio_distance_mm"] = bioMM;
  doc["nb_distance_mm"]  = nbMM;
  doc["bio_servo_open"]  = bioOpen;
  doc["nb_servo_open"]   = nbOpen;

  String body; serializeJson(doc, body);
  int code = http.POST(body);
  http.end();

  bool ok = (code == 200 || code == 201);
  Serial.println("[Supabase] push " + String(ok ? "OK" : "FAIL") +
                 " HTTP " + String(code) +
                 "  bio=" + String((bioLvl<0)?0:bioLvl) + "%" +
                 " nb="  + String((nbLvl <0)?0:nbLvl)  + "%");
  return ok;
}


// ================================================================
// EXECUTE COMMAND
//
// Called DIRECTLY from the WiFi task (Core 0).
// servo.write() and digitalWrite() use ESP32 hardware peripherals
// (LEDC / GPIO) and are safe to call from any core.
// No inter-core handoff needed — this is the fix.
// ================================================================
void executeCommand(const String& cmd) {
  Serial.println("[CMD] Executing: " + cmd);

  if (cmd == "open_bio_lid") {
    servo1.write(SERVO_OPEN);
    bioServoOpen = true;
    bioTimerVolatile = millis();
    Serial.println("[CMD] Bio lid OPENED");

  } else if (cmd == "close_bio_lid") {
    servo1.write(SERVO_CLOSED);
    bioServoOpen = false;
    Serial.println("[CMD] Bio lid CLOSED");

  } else if (cmd == "open_nb_lid") {
    servo2.write(SERVO_OPEN);
    nonBioServoOpen = true;
    nonBioTimerVolatile = millis();
    Serial.println("[CMD] NonBio lid OPENED");

  } else if (cmd == "close_nb_lid") {
    servo2.write(SERVO_CLOSED);
    nonBioServoOpen = false;
    Serial.println("[CMD] NonBio lid CLOSED");

  } else if (cmd == "open_all_lids") {
    servo1.write(SERVO_OPEN);  servo2.write(SERVO_OPEN);
    bioServoOpen = nonBioServoOpen = true;
    bioTimerVolatile = nonBioTimerVolatile = millis();
    Serial.println("[CMD] All lids OPENED");

  } else if (cmd == "close_all_lids") {
    servo1.write(SERVO_CLOSED); servo2.write(SERVO_CLOSED);
    bioServoOpen = nonBioServoOpen = false;
    Serial.println("[CMD] All lids CLOSED");

  } else if (cmd == "buzzer_on") {
    shortBeep();

  } else if (cmd == "buzzer_off") {
    digitalWrite(BUZZER, LOW);

  } else if (cmd == "reset_bio") {
    currentBioLevel = 0;
    bioWarnLogged = bioFullLogged = false;

  } else if (cmd == "reset_nb") {
    currentNbLevel = 0;
    nbWarnLogged = nbFullLogged = false;

  } else if (cmd == "reset_all") {
    currentBioLevel = currentNbLevel = 0;
    bioWarnLogged = bioFullLogged = nbWarnLogged = nbFullLogged = false;

  } else if (cmd == "trigger_bio_us") {
    if (currentBioLevel < 100) {
      servo1.write(SERVO_OPEN);
      bioServoOpen = true;
      bioTimerVolatile = millis();
      shortBeep();
    }

  } else if (cmd == "trigger_nb_us") {
    if (currentNbLevel < 100) {
      servo2.write(SERVO_OPEN);
      nonBioServoOpen = true;
      nonBioTimerVolatile = millis();
      shortBeep();
    }

  } else if (cmd == "led_bio_green") {
    digitalWrite(LED_BIO_GREEN, HIGH); digitalWrite(LED_BIO_RED,      LOW);

  } else if (cmd == "led_bio_red") {
    digitalWrite(LED_BIO_RED,   HIGH); digitalWrite(LED_BIO_GREEN,    LOW);

  } else if (cmd == "led_nb_green") {
    digitalWrite(LED_NONBIO_GREEN, HIGH); digitalWrite(LED_NONBIO_RED, LOW);

  } else if (cmd == "led_nb_red") {
    digitalWrite(LED_NONBIO_RED,   HIGH); digitalWrite(LED_NONBIO_GREEN, LOW);

  } else if (cmd == "request_status") {
    Serial.println("[CMD] Status push queued.");

  } else {
    Serial.println("[CMD] Unknown command: " + cmd);
  }
}


// ================================================================
// MARK COMMAND EXECUTED
// ================================================================
void markCommandExecuted(long cmdId) {
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;

  String url = String(SUPABASE_URL)
    + "/rest/v1/bin_commands"
    + "?id=eq." + String(cmdId)
    + "&device_id=eq." + String(DEVICE_ID);

  http.begin(client, url);
  http.addHeader("Content-Type",  "application/json");
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);
  http.addHeader("Prefer",        "return=minimal");

  StaticJsonDocument<64> doc;
  doc["status"] = "executed";
  String body; serializeJson(doc, body);

  int code = http.PATCH(body);
  http.end();
  Serial.println("[CMD] Marked executed id=" + String(cmdId) + " HTTP " + String(code));
}


// ================================================================
// POLL bin_commands
//
// FIX: executeCommand() is called HERE, directly on Core 0.
// No volatile flag, no 200 ms timeout, no missed windows.
// servo.write() / digitalWrite() are hardware-peripheral calls —
// safe from any core on the ESP32.
// ================================================================
void pollCommands() {
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;

  String url = String(SUPABASE_URL)
    + "/rest/v1/bin_commands"
    + "?device_id=eq." + String(DEVICE_ID)
    + "&status=eq.pending"
    + "&order=created_at.asc"
    + "&limit=5"
    + "&select=id,command";

  http.begin(client, url);
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);

  int code = http.GET();
  if (code != 200) {
    http.end();
    Serial.println("[CMD] Poll HTTP " + String(code) + " — check Supabase RLS policies");
    return;
  }

  String payload = http.getString();
  http.end();

  DynamicJsonDocument resp(1024);
  if (deserializeJson(resp, payload) || !resp.is<JsonArray>()) return;

  JsonArray arr = resp.as<JsonArray>();
  if (arr.size() == 0) return;

  Serial.println("[CMD] " + String(arr.size()) + " pending command(s).");

  for (JsonObject item : arr) {
    long   id  = item["id"].as<long>();
    String cmd = item["command"].as<String>();

    // Execute immediately on Core 0 — no handoff required
    executeCommand(cmd);

    // Mark done and push fresh status
    markCommandExecuted(id);
    pushBinLog(currentBioLevel, currentNbLevel,
               currentBioMM,   currentNbMM,
               bioServoOpen,   nonBioServoOpen);
  }
}


