  doc["ip_address"]     = WiFi.localIP().toString();
  doc["wifi_rssi"]      = WiFi.RSSI();

  String body;
  serializeJson(doc, body);

  http.PATCH(body);
  http.end();
}


// ================================================================
// GAS EMAIL ALERT
// Sends alert and then updates alert_history.email_status in DB.
// ================================================================
bool sendGASAlert(const char* binType, int level, const char* alertType) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[GAS] No WiFi — alert skipped.");
    return false;
  }

  // Build subject line
  String subject;
  if (strcmp(alertType, "full") == 0) {
    subject = "SmartBin FULL: " + String(binType) + " bin — Disposal Required";
  } else if (strcmp(alertType, "warn") == 0) {
    subject = "SmartBin Warning: " + String(binType) + " bin at " + String(level) + "%";
  } else {
    subject = "SmartBin: " + String(binType) + " bin emptied";
  }

  // Plain-text body
  String bodyTxt = "SmartBin IoT Alert\n\n"
    "Bin: " + String(binType) + "\n"
    "Level: " + String(level) + "%\n"
    "Status: " + String(alertType) + "\n"
    "Device: " + String(DEVICE_ID) + "\n\n"
    "This is an automated message from SmartBin IoT.";

  // JSON payload for GAS relay
  StaticJsonDocument<512> doc;
  doc["recipients"] = ALERT_EMAILS;
  doc["subject"]    = subject;
  doc["body"]       = bodyTxt;
  doc["binType"]    = binType;
  doc["alertType"]  = alertType;
  doc["level"]      = level;

  String payload;
  serializeJson(doc, payload);

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  http.begin(client, GAS_URL);
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
  http.addHeader("Content-Type", "application/json");

  int code = http.POST(payload);
  String resp = http.getString();
  http.end();

  Serial.println("[GAS] HTTP " + String(code) + " → " + resp);

  // Determine success and update alert_history in DB
  bool success = (code == 200 && resp.indexOf("\"ok\":true") >= 0);

  // binType from GAS payload is the human name ("Biodegradable") — map to DB column value
  // alert_history.bin_type CHECK: 'bio' | 'nonbio' | 'test'
  String dbBinType = (String(binType).indexOf("Bio") >= 0 &&
                      String(binType).indexOf("Non") < 0) ? "bio" : "nonbio";

  updateAlertEmailStatus(dbBinType, String(alertType), success ? "sent" : "failed");

  return success;
}


