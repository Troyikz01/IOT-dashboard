void connectWiFi() {
  Serial.print("[WiFi] Connecting to ");
  Serial.print(WIFI_SSID);
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n[WiFi] Connected! IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("\n[WiFi] FAILED — running offline.");
  }
}


// ================================================================
// SUPABASE — POST to bin_logs
//
// Columns written (matches supabase_schema.sql):
//   bio_level, nb_level
//   bio_distance_mm, nb_distance_mm
//   bio_status, nb_status
//   bio_servo_open, nb_servo_open
//   event_type  ('reading' | 'alert' | 'disposal' | 'startup')
//   alert_bin   ('bio' | 'nonbio' | NULL)
//   notes
//   device_id
//
// The three triggers in the DB handle the rest automatically:
//   trg_update_device_status → keeps device_status fresh
//   trg_log_disposal         → writes to disposal_events
//   trg_log_alert            → writes to alert_history (status: pending)
// ================================================================
bool postBinLog(
  int bioLevel,   int nbLevel,
  int bioMM,      int nbMM,
  String bioStat, String nbStat,
  bool bioOpen,   bool nbOpen,
  String eventType,
  String alertBin,   // pass empty string "" to store NULL
  String notes
) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[Supabase] No WiFi — skipping push.");
    return false;
  }

  WiFiClientSecure client;
  client.setInsecure();  // skip SSL cert check (standard for ESP32)

  HTTPClient http;
  String url = String(SUPABASE_URL) + "/rest/v1/bin_logs";
  http.begin(client, url);
  http.addHeader("Content-Type",  "application/json");
  http.addHeader("apikey",         SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);
  http.addHeader("Prefer",        "return=minimal");  // don't return the row, saves bandwidth

  // Build JSON payload
  StaticJsonDocument<512> doc;
  doc["bio_level"]       = bioLevel;
  doc["nb_level"]        = nbLevel;
  doc["bio_distance_mm"] = bioMM;
  doc["nb_distance_mm"]  = nbMM;
  doc["bio_status"]      = bioStat;
  doc["nb_status"]       = nbStat;
  doc["bio_servo_open"]  = bioOpen;
  doc["nb_servo_open"]   = nbOpen;
  doc["event_type"]      = eventType;
  doc["device_id"]       = DEVICE_ID;

  // alert_bin is nullable — only include when it has a value
  if (alertBin.length() > 0) {
    doc["alert_bin"] = alertBin;
  } else {
    doc["alert_bin"] = (char*)NULL;  // explicit NULL for the column
  }

  if (notes.length() > 0) {
    doc["notes"] = notes;
  }

  String body;
  serializeJson(doc, body);

  int code = http.POST(body);
  http.end();

  if (code == 201 || code == 200) {
    Serial.println("[Supabase] bin_logs INSERT OK (HTTP " + String(code) + ")");
    return true;
  } else {
    Serial.println("[Supabase] INSERT FAILED (HTTP " + String(code) + ")");
    return false;
  }
}


// ================================================================
// SUPABASE — UPDATE alert_history email_status
// Called after GAS responds so the DB shows 'sent' or 'failed'
// instead of leaving it as 'pending' forever.
// ================================================================
void updateAlertEmailStatus(String binType, String alertType, String status) {
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  // PATCH the most recent matching alert_history row
  String url = String(SUPABASE_URL)
    + "/rest/v1/alert_history"
    + "?bin_type=eq." + binType
    + "&alert_type=eq." + alertType
    + "&email_status=eq.pending"
    + "&order=created_at.desc&limit=1";

  http.begin(client, url);
  http.addHeader("Content-Type",  "application/json");
  http.addHeader("apikey",         SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);
  http.addHeader("Prefer",        "return=minimal");

  StaticJsonDocument<64> doc;
  doc["email_status"] = status;   // "sent" or "failed"
  String body;
  serializeJson(doc, body);

  http.PATCH(body);
  http.end();
}


