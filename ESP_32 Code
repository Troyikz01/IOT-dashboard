// ================================================================
// FILL LEVEL
// ================================================================
int mmToPercent(int d) {
  if (d > 8000 || d < 0) return -1;
  if (d >= BIN_EMPTY_MM) return 0;
  if (d <= BIN_FULL_MM)  return 100;
  return (int)map(d, BIN_FULL_MM, BIN_EMPTY_MM, 100, 0);
}


// ================================================================
// BUZZER HELPERS
// ================================================================
void shortBeep() {
  digitalWrite(BUZZER, HIGH);
  delay(150);
  digitalWrite(BUZZER, LOW);
}

void longBeep() {
  digitalWrite(BUZZER, HIGH);
  delay(1500);
  digitalWrite(BUZZER, LOW);
}


// ================================================================
// ULTRASONIC HELPER
// ================================================================
float getDistanceInches(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  long duration = pulseIn(echoPin, HIGH, 25000);
  if (duration == 0) return 99.0;
  return (duration * 0.0343 / 2.0) / 2.54;
}


// ================================================================
// WiFi connect
// ================================================================
void connectWiFi() {
  Serial.print("[WiFi] Connecting to "); Serial.print(WIFI_SSID);
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 20) {
    delay(500); Serial.print("."); tries++;
  }
  if (WiFi.status() == WL_CONNECTED)
    Serial.println("\n[WiFi] Connected! IP: " + WiFi.localIP().toString());
  else
    Serial.println("\n[WiFi] FAILED — running offline.");
}


// ================================================================
// SUPABASE — Push bin_logs
// ================================================================
bool pushBinLog(int bioLvl, int nbLvl,
                int bioMM,  int nbMM,
                bool bioOpen, bool nbOpen) {

  if (WiFi.status() != WL_CONNECTED) return false;

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  String url = String(SUPABASE_URL) + "/rest/v1/bin_logs";
  http.begin(client, url);
  http.addHeader("Content-Type",  "application/json");
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);
  http.addHeader("Prefer",        "return=minimal");

  StaticJsonDocument<256> doc;
  doc["device_id"]       = DEVICE_ID;
  doc["bio_level"]       = (bioLvl < 0) ? 0 : bioLvl;
  doc["nb_level"]        = (nbLvl  < 0) ? 0 : nbLvl;
  doc["bio_distance_mm"] = bioMM;
  doc["nb_distance_mm"]  = nbMM;
  doc["bio_servo_open"]  = bioOpen;
  doc["nb_servo_open"]   = nbOpen;

  String body;
  serializeJson(doc, body);

  int code = http.POST(body);
  http.end();

  bool ok = (code == 200 || code == 201);
  Serial.println("[Supabase] push " + String(ok ? "OK" : "FAIL") +
                 " (HTTP " + String(code) + ")  bio=" +
                 String((bioLvl < 0) ? 0 : bioLvl) + "% nb=" +
                 String((nbLvl  < 0) ? 0 : nbLvl)  + "%");
  return ok;
}


// ================================================================
// MARK COMMAND EXECUTED
// ================================================================
void markCommandExecuted(long cmdId) {
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  String url = String(SUPABASE_URL)
    + "/rest/v1/bin_commands"
    + "?id=eq." + String(cmdId)
    + "&device_id=eq." + String(DEVICE_ID);

  http.begin(client, url);
  http.addHeader("Content-Type",  "application/json");
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);
  http.addHeader("Prefer",        "return=minimal");

  StaticJsonDocument<64> doc;
  doc["status"] = "executed";
  String body;
  serializeJson(doc, body);

  int code = http.PATCH(body);
  http.end();

  Serial.println("[CMD] Marked executed (id=" + String(cmdId) +
                 ") HTTP " + String(code));
}


// ================================================================
// POLL bin_commands
// ================================================================
void pollCommands() {
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  String url = String(SUPABASE_URL)
    + "/rest/v1/bin_commands"
    + "?device_id=eq." + String(DEVICE_ID)
    + "&status=eq.pending"
    + "&order=created_at.asc"
    + "&limit=5"
    + "&select=id,command";

  http.begin(client, url);
  http.addHeader("apikey",        SUPABASE_KEY);
  http.addHeader("Authorization", String("Bearer ") + SUPABASE_KEY);

  int code = http.GET();
  if (code != 200) { http.end(); return; }

  String payload = http.getString();
  http.end();

  DynamicJsonDocument resp(1024);
  if (deserializeJson(resp, payload) || !resp.is<JsonArray>()) return;

  JsonArray arr = resp.as<JsonArray>();
  if (arr.size() == 0) return;

  Serial.println("[CMD] " + String(arr.size()) + " command(s) found.");

  for (JsonObject item : arr) {
    long   id  = item["id"].as<long>();
    String cmd = item["command"].as<String>();

    // Hand command off to main loop — all hardware lives on Core 1
    strncpy((char*)pendingCmdStr, cmd.c_str(), sizeof(pendingCmdStr) - 1);
    pendingCmdId = id;
    pendingCmd   = true;

    // Wait up to 200 ms for main loop to pick it up
    unsigned long t = millis();
    while (pendingCmd && millis() - t < 200) delay(10);

    markCommandExecuted(id);
    pushBinLog(currentBioLevel, currentNbLevel,
               currentBioMM,   currentNbMM,
               bioServoOpen,   nonBioServoOpen);
  }
}


// ================================================================
// EXECUTE COMMAND — called from main loop (Core 1) only
// ================================================================
void executeCommand(const char* cmd) {
  Serial.println("[CMD] Executing: " + String(cmd));

  if      (strcmp(cmd, "open_bio_lid")   == 0) { servo1.write(SERVO_OPEN);   bioServoOpen = true;  bioTimer = millis(); }
  else if (strcmp(cmd, "close_bio_lid")  == 0) { servo1.write(SERVO_CLOSED); bioServoOpen = false; }
  else if (strcmp(cmd, "open_nb_lid")    == 0) { servo2.write(SERVO_OPEN);   nonBioServoOpen = true;  nonBioTimer = millis(); }
  else if (strcmp(cmd, "close_nb_lid")   == 0) { servo2.write(SERVO_CLOSED); nonBioServoOpen = false; }
  else if (strcmp(cmd, "open_all_lids")  == 0) {
    servo1.write(SERVO_OPEN); servo2.write(SERVO_OPEN);
    bioServoOpen = nonBioServoOpen = true;
    bioTimer = nonBioTimer = millis();
  }
  else if (strcmp(cmd, "close_all_lids") == 0) {
    servo1.write(SERVO_CLOSED); servo2.write(SERVO_CLOSED);
    bioServoOpen = nonBioServoOpen = false;
  }
  else if (strcmp(cmd, "buzzer_on")  == 0) { shortBeep(); }
  else if (strcmp(cmd, "buzzer_off") == 0) { digitalWrite(BUZZER, LOW); }
  else if (strcmp(cmd, "reset_bio")  == 0) { currentBioLevel = 0; bioWarnLogged = bioFullLogged = false; }
  else if (strcmp(cmd, "reset_nb")   == 0) { currentNbLevel  = 0; nbWarnLogged  = nbFullLogged  = false; }
  else if (strcmp(cmd, "reset_all")  == 0) {
    currentBioLevel = currentNbLevel = 0;
    bioWarnLogged = bioFullLogged = nbWarnLogged = nbFullLogged = false;
  }
  else if (strcmp(cmd, "trigger_bio_us") == 0) {
    if (currentBioLevel < 100) { servo1.write(SERVO_OPEN); bioServoOpen = true; bioTimer = millis(); shortBeep(); }
  }
  else if (strcmp(cmd, "trigger_nb_us") == 0) {
    if (currentNbLevel < 100) { servo2.write(SERVO_OPEN); nonBioServoOpen = true; nonBioTimer = millis(); shortBeep(); }
  }
  else if (strcmp(cmd, "led_bio_green")  == 0) { digitalWrite(LED_BIO_GREEN,    HIGH); digitalWrite(LED_BIO_RED,      LOW); }
  else if (strcmp(cmd, "led_bio_red")    == 0) { digitalWrite(LED_BIO_RED,       HIGH); digitalWrite(LED_BIO_GREEN,    LOW); }
  else if (strcmp(cmd, "led_nb_green")   == 0) { digitalWrite(LED_NONBIO_GREEN,  HIGH); digitalWrite(LED_NONBIO_RED,   LOW); }
  else if (strcmp(cmd, "led_nb_red")     == 0) { digitalWrite(LED_NONBIO_RED,    HIGH); digitalWrite(LED_NONBIO_GREEN, LOW); }
  else if (strcmp(cmd, "request_status") == 0) { Serial.println("[CMD] Status push queued."); }
  else { Serial.println("[CMD] Unknown: " + String(cmd)); }
}


