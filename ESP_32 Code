void updateOLED(
  String bioStat, String nbStat,
  float bioDist,  float nbDist,
  bool wifiOk
) {
  display.clearDisplay();
  display.setCursor(0, 0);
  display.println("SMART BIN SYSTEM");

  display.setCursor(0, 15);
  display.print("BIO: ");
  display.println(bioStat);

  display.setCursor(0, 30);
  display.print("NON: ");
  display.println(nbStat);

  display.setCursor(0, 50);

  // Priority 1: Full warning
  if (bioStat == "100% FULL" || nbStat == "100% FULL") {
    display.println("STATUS: BIN FULL!");
  }
  // Priority 2: Hand/trash detected
  else if (bioDist <= 5.0 || nbDist <= 5.0) {
    display.println(">> TRASH DETECTED");
  }
  // Priority 3: Ready
  else {
    display.print(wifiOk ? "STATUS: READY" : "WiFi: OFFLINE");
  }

  display.display();
}


