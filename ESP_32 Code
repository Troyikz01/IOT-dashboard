// ================================================================
// BIN STATUS FUNCTION
// Mirrors the database function fn_mm_to_level() and fn_getStatus().
// Returns a human-readable string AND a fill-% integer.
// ================================================================

// Returns fill % integer: 0 / 25 / 50 / 75 / 100
// Returns -1 on sensor error (maps to "SENSOR ERR" — not inserted to DB)
int mmToLevel(int d) {
  if (d > 8000 || d < 0) return -1;  // sensor error
  if (d > 250)            return 0;
  if (d <= 90)            return 100;
  if (d <= 130)           return 75;
  if (d <= 170)           return 50;
  if (d <= 210)           return 25;
  return 0;
}

// Returns the human-readable status string stored in bio_status / nb_status columns
String levelToStatus(int level) {
  if (level < 0)  return "SENSOR ERR";
  if (level == 0) return "0% FULL";
  return String(level) + "% FULL";  // "25% FULL", "50% FULL", "75% FULL", "100% FULL"
}


