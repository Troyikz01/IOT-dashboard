// ================================================================
// WIFI TASK — runs on Core 0
//
// All blocking HTTP calls (pushBinLog, pollCommands) live here.
// Core 1 (main loop) is never stalled by network I/O.
// ================================================================
void wifiTask(void* parameter) {
  unsigned long lastPush      = 0;
  unsigned long lastCmdPoll   = 0;
  unsigned long lastReconnect = 0;

  for (;;) {
    unsigned long now = millis();

    // WiFi watchdog
    if (WiFi.status() != WL_CONNECTED && now - lastReconnect >= 30000) {
      lastReconnect = now;
      Serial.println("[WiFi] Reconnecting...");
      WiFi.reconnect();
    }

    // Heartbeat push every 3 s
    if (now - lastPush >= PUSH_INTERVAL) {
      lastPush = now;
      pushBinLog(currentBioLevel, currentNbLevel,
                 currentBioMM,   currentNbMM,
                 bioServoOpen,   nonBioServoOpen);
    }

    // Command poll every 3 s
    if (now - lastCmdPoll >= CMD_POLL_INTERVAL) {
      lastCmdPoll = now;
      pollCommands();
    }

    vTaskDelay(10 / portTICK_PERIOD_MS);
  }
}


// ================================================================
// SETUP
// ================================================================
void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  // OLED boot screen
  display.begin(0x3C, true);
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);
  display.setCursor(0, 0);
  display.println("SmartBin IoT v2.1");
  display.println("Group 5 IT38B NBSC");
  display.println("");
  display.println("Booting...");
  display.display();

  // GPIO
  pinMode(LED_BIO_RED,      OUTPUT);
  pinMode(LED_BIO_GREEN,    OUTPUT);
  pinMode(LED_NONBIO_RED,   OUTPUT);
  pinMode(LED_NONBIO_GREEN, OUTPUT);
  pinMode(BUZZER,           OUTPUT);
  pinMode(TRIG1, OUTPUT); pinMode(ECHO1, INPUT);
  pinMode(TRIG2, OUTPUT); pinMode(ECHO2, INPUT);
  pinMode(XSHUT1, OUTPUT);
  pinMode(XSHUT2, OUTPUT);

  // Default LED state — green on boot
  digitalWrite(LED_BIO_GREEN,    HIGH);
  digitalWrite(LED_BIO_RED,      LOW);
  digitalWrite(LED_NONBIO_GREEN, HIGH);
  digitalWrite(LED_NONBIO_RED,   LOW);
  digitalWrite(BUZZER,           LOW);

  // Servos
  servo1.setPeriodHertz(50);
  servo2.setPeriodHertz(50);
  servo1.attach(SERVO1_PIN, 500, 2400);
  servo2.attach(SERVO2_PIN, 500, 2400);
  servo1.write(SERVO_CLOSED);
  servo2.write(SERVO_CLOSED);

  // VL53L0X init
  digitalWrite(XSHUT1, LOW);
  digitalWrite(XSHUT2, LOW);
  delay(100);

  digitalWrite(XSHUT1, HIGH);
  delay(100);
  if (sensor1.init()) {
    sensor1.setAddress(0x30);
    sensor1.setTimeout(500);
    Serial.println("[VL53L0X] BIO OK @ 0x30");
  } else {
    Serial.println("[VL53L0X] BIO SENSOR FAILED");
  }

  digitalWrite(XSHUT2, HIGH);
  delay(100);
  if (sensor2.init()) {
    sensor2.setAddress(0x31);
    sensor2.setTimeout(500);
    Serial.println("[VL53L0X] NON-BIO OK @ 0x31");
  } else {
    Serial.println("[VL53L0X] NON-BIO SENSOR FAILED");
  }

  // WiFi
  display.clearDisplay();
  display.setCursor(0, 0);
  display.println("Connecting WiFi...");
  display.println(WIFI_SSID);
  display.display();
  connectWiFi();

  // Launch WiFi/HTTP task on Core 0
  // main loop() runs on Core 1 — sensor & servo only, no blocking
  xTaskCreatePinnedToCore(
    wifiTask,    // function
    "WiFiTask",  // name (for debugging)
    8192,        // stack bytes — needs room for TLS + JSON buffers
    NULL,        // parameter
    1,           // priority
    NULL,        // task handle (not needed)
    0            // Core 0
  );

  Serial.println("[System] READY — WiFi task on Core 0, sensors/servos on Core 1.");
}


// ================================================================
// LOOP — Core 1 only: sensors, servos, LEDs, OLED
//
// No HTTP calls here. The WiFi task on Core 0 handles all network
// I/O so this loop is never stalled — lid opens the instant the
// ultrasonic sensor detects an object, every single time.
// ================================================================
void loop() {
  unsigned long now = millis();

  // ════════════════════════════════════════════════════════════
  // 1. READ VL53L0X (fill level)
  // ════════════════════════════════════════════════════════════
  int rawBioMM = sensor1.readRangeSingleMillimeters();
  int rawNbMM  = sensor2.readRangeSingleMillimeters();

  int bioLvl = mmToPercent(rawBioMM);
  int nbLvl  = mmToPercent(rawNbMM);

  if (bioLvl >= 0) { currentBioLevel = bioLvl; currentBioMM = rawBioMM; }
  if (nbLvl  >= 0) { currentNbLevel  = nbLvl;  currentNbMM  = rawNbMM;  }

  // ════════════════════════════════════════════════════════════
  // 2. READ ULTRASONIC (hand/object detection)
  // ════════════════════════════════════════════════════════════
  bioDist = getDistanceInches(TRIG1, ECHO1);
  nbDist  = getDistanceInches(TRIG2, ECHO2);

  // ════════════════════════════════════════════════════════════
  // 3. PROCESS PENDING DASHBOARD COMMAND (from WiFi task)
  // All hardware access stays on Core 1.
  // ════════════════════════════════════════════════════════════
  if (pendingCmd) {
    executeCommand((const char*)pendingCmdStr);
    pendingCmd = false;  // release WiFi task to continue
  }

  // ════════════════════════════════════════════════════════════
  // 4. LED LOGIC
  // ════════════════════════════════════════════════════════════
  bool bioFull = (currentBioLevel >= 100);
  bool nbFull  = (currentNbLevel  >= 100);

  digitalWrite(LED_BIO_RED,      bioFull ? HIGH : LOW);
  digitalWrite(LED_BIO_GREEN,    bioFull ? LOW  : HIGH);
  digitalWrite(LED_NONBIO_RED,   nbFull  ? HIGH : LOW);
  digitalWrite(LED_NONBIO_GREEN, nbFull  ? LOW  : HIGH);

  // ════════════════════════════════════════════════════════════
  // 5. BIO BIN
  //    Open:  INSTANT the moment object is detected.
  //    Close: 3 seconds after opening, no sooner.
  // ════════════════════════════════════════════════════════════
  if (bioDist <= 5.0 && !bioServoOpen && !bioFull) {
    servo1.write(SERVO_OPEN);  // instant — Core 1 is never stalled
    bioServoOpen = true;
    bioTimer = now;
  }
  if (bioDist <= 5.0 && !bioBuzzLock) {
    bioBuzzLock = true;
    bioFull ? longBeep() : shortBeep();
  }
  if (bioDist > 6.0) bioBuzzLock = false;

  if (bioServoOpen && (now - bioTimer >= 3000)) {
    servo1.write(SERVO_CLOSED);
    bioServoOpen = false;
  }

  // ════════════════════════════════════════════════════════════
  // 6. NON-BIO BIN — same logic
  // ════════════════════════════════════════════════════════════
  if (nbDist <= 5.0 && !nonBioServoOpen && !nbFull) {
    servo2.write(SERVO_OPEN);  // instant
    nonBioServoOpen = true;
    nonBioTimer = now;
  }
  if (nbDist <= 5.0 && !nonBioBuzzLock) {
    nonBioBuzzLock = true;
    nbFull ? longBeep() : shortBeep();
  }
  if (nbDist > 6.0) nonBioBuzzLock = false;

  if (nonBioServoOpen && (now - nonBioTimer >= 3000)) {
    servo2.write(SERVO_CLOSED);
    nonBioServoOpen = false;
  }

  // ════════════════════════════════════════════════════════════
  // 7. THRESHOLD LOGGING
  // ════════════════════════════════════════════════════════════
  if (currentBioLevel >= 75 && !bioWarnLogged) {
    bioWarnLogged = true;
    Serial.println("[ALERT] Bio bin at " + String(currentBioLevel) + "% — HIGH");
  }
  if (currentBioLevel < 75) bioWarnLogged = false;

  if (currentBioLevel >= 100 && !bioFullLogged) {
    bioFullLogged = true;
    Serial.println("[ALERT] Bio bin FULL — disposal required");
  }
  if (currentBioLevel < 100) bioFullLogged = false;

  if (currentNbLevel >= 75 && !nbWarnLogged) {
    nbWarnLogged = true;
    Serial.println("[ALERT] NonBio bin at " + String(currentNbLevel) + "% — HIGH");
  }
  if (currentNbLevel < 75) nbWarnLogged = false;

  if (currentNbLevel >= 100 && !nbFullLogged) {
    nbFullLogged = true;
    Serial.println("[ALERT] NonBio bin FULL — disposal required");
  }
  if (currentNbLevel < 100) nbFullLogged = false;

  // ════════════════════════════════════════════════════════════
  // 8. OLED UPDATE
  // ════════════════════════════════════════════════════════════
  updateOLED(currentBioLevel, currentNbLevel,
             bioDist, nbDist,
             WiFi.status() == WL_CONNECTED);

  // ════════════════════════════════════════════════════════════
  // 9. SERIAL DEBUG
  // ════════════════════════════════════════════════════════════
  Serial.printf("[BIO]  %4d mm → %3d%%  US: %.1f in  Servo: %s\n",
                currentBioMM, currentBioLevel,
                bioDist, bioServoOpen ? "OPEN" : "CLOSED");
  Serial.printf("[NONB] %4d mm → %3d%%  US: %.1f in  Servo: %s\n",
                currentNbMM, currentNbLevel,
                nbDist, nonBioServoOpen ? "OPEN" : "CLOSED");
  Serial.printf("[WiFi] %s  RSSI: %d dBm\n",
                WiFi.status() == WL_CONNECTED ? "OK" : "OFFLINE",
                WiFi.RSSI());
  Serial.println("---");

  delay(50);
}
