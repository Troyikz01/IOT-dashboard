}


// ================================================================
// ULTRASONIC HELPER (original, unchanged)
// ================================================================
float getDistanceInches(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  long duration = pulseIn(echoPin, HIGH, 25000); // 25 ms timeout
  if (duration == 0) return 99.0;
  return (duration * 0.0343 / 2) / 2.54;
}


// ================================================================
// WiFi
